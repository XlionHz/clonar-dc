# Clonar DC central API
CLONARDC_ENV=staging
CLONARDC_ADMIN_EMAIL=admin@example.com
CLONARDC_ADMIN_PASSWORD=replace-with-a-long-random-password
CLONARDC_PUBLIC_URL=https://your-api.example.com
DATABASE_URL=postgresql://user:password@host:5432/database

# Mercado Pago — keep these values only in the hosting provider's secret manager
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_USE_SANDBOX=true
MERCADOPAGO_ALLOW_UNSIGNED_WEBHOOKS=false

# Prices in BRL. A missing or zero price disables that plan.
CLONARDC_PRICE_1M=0
CLONARDC_PRICE_3M=0
CLONARDC_PRICE_6M=0
CLONARDC_PRICE_12M=0
CLONARDC_PRICE_PERMANENT=0
