<Application x:Class="ClonarDC.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#090A11"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#11131D"/>
        <SolidColorBrush x:Key="Panel2Brush" Color="#171A27"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#292D40"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F1FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A8A4B8"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="Purple2Brush" Color="#6D28D9"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FB7185"/>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D0F18"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#0D0F18"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D0F18"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="9,7"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#201A35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C357D"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Purple2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PurpleBrush}"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
    </Application.Resources>
</Application>
