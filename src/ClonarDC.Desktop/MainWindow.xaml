<Window x:Class="ClonarDC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clonar DC" Icon="/ClonarDC;component/Assets/ClonarDC.ico"
        Width="1380" Height="860" MinWidth="1100" MinHeight="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="235"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0B0C14" BorderBrush="#242637" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="4,6,4,26">
                    <Image Source="/ClonarDC;component/Assets/ClonarDCLogo.png" Width="46" Height="46"/>
                    <StackPanel Margin="11,2,0,0"><TextBlock Text="Clonar DC" FontSize="17" FontWeight="Bold"/><TextBlock Text="Desktop" FontSize="11" Foreground="{StaticResource MutedBrush}"/></StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Tag="0" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="⌂" Width="26"/><TextBlock Text="Overview"/></StackPanel></Button>
                    <Button Style="{StaticResource NavButton}" Tag="1" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="⧉" Width="26"/><TextBlock Text="Cloning"/></StackPanel></Button>
                    <Button Style="{StaticResource NavButton}" Tag="2" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="▣" Width="26"/><TextBlock Text="Backups"/></StackPanel></Button>
                    <Button Style="{StaticResource NavButton}" Tag="3" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="≡" Width="26"/><TextBlock Text="Operations"/></StackPanel></Button>
                    <Button Style="{StaticResource NavButton}" Tag="4" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="◇" Width="26"/><TextBlock Text="License"/></StackPanel></Button>
                    <Button Style="{StaticResource NavButton}" Tag="5" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="⚙" Width="26"/><TextBlock Text="Settings"/></StackPanel></Button>
                    <Button x:Name="AdminNav" Style="{StaticResource NavButton}" Tag="6" Click="Nav_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="◆" Width="26"/><TextBlock Text="Administration"/></StackPanel></Button>
                </StackPanel>
                <Border Grid.Row="2" Background="#12141D" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="UserNameText" FontWeight="SemiBold"/>
                        <TextBlock x:Name="UserEmailText" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="VersionText" Foreground="#7C7890" FontSize="10" Margin="0,6,0,0"/>
                        <Button Content="Sign out" Margin="0,11,0,0" Padding="10,7" Click="Logout_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="Pages" Grid.Column="1" Background="{StaticResource BgBrush}" BorderThickness="0" SelectionChanged="Pages_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style>
            </TabControl.Resources>

            <TabItem Header="Overview"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34">
                <TextBlock Text="Overview" FontSize="30" FontWeight="Bold"/><TextBlock Text="Quick control of your Clonar DC environment." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,26"/>
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="License" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="DashboardLicense" FontSize="21" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="Local backups" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="DashboardBackups" FontSize="21" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20"><StackPanel><TextBlock Text="Last operation" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="DashboardLastOperation" Text="None in this session" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                </UniformGrid>
                <Border Background="#151225" BorderBrush="#44336F" BorderThickness="1" CornerRadius="14" Padding="24">
                    <StackPanel><TextBlock Text="Safe workflow" FontSize="20" FontWeight="Bold"/><TextBlock Text="1. Enter the credential value  →  2. Use it locally  →  3. Load servers when ready  →  4. Analyze differences  →  5. Create a backup  →  6. Clone." Foreground="#C4B5FD" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel>
                </Border>
            </StackPanel></ScrollViewer></TabItem>

            <TabItem Header="Cloning"><Grid Margin="34"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel><TextBlock Text="Cloning" FontSize="30" FontWeight="Bold"/><TextBlock Text="Any text can be stored in the Token field. Discord is contacted only when you load servers or start an operation." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22" TextWrapping="Wrap"/></StackPanel>
                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Token"/>
                            <Grid Margin="0,6,0,14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <PasswordBox x:Name="TokenBox" Height="42"/>
                                <Button Grid.Column="1" Content="Use locally" Margin="9,0,0,0" Click="AcceptTokenWithoutValidation_Click"/>
                                <Button Grid.Column="2" Content="Load servers" Margin="9,0,0,0" Click="LoadServers_Click"/>
                            </Grid>
                            <TextBlock Text="Source server"/><ComboBox x:Name="SourceGuildBox" Height="42" Margin="0,6,0,14"/>
                            <TextBlock Text="Destination server"/><ComboBox x:Name="TargetGuildBox" Height="42" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                            <TextBlock Text="Mode"/><ComboBox x:Name="ModeBox" Height="42" Margin="0,6,0,14" SelectedIndex="0"><ComboBoxItem Content="Safe — only adds missing items" Tag="safe"/><ComboBoxItem Content="Merge — preserves matching items" Tag="merge"/><ComboBoxItem Content="Safe exact — recreates the destination" Tag="exact"/></ComboBox>
                            <TextBlock Text="Protections"/><CheckBox x:Name="AutoBackupCheck" Content="Automatically back up the destination" IsChecked="True" Margin="0,8,0,5"/><CheckBox x:Name="RememberTokenCheck" Content="Remember Token using Windows protection" Margin="0,2,0,18"/>
                            <StackPanel Orientation="Horizontal"><Button Content="Analyze" Click="Analyze_Click"/><Button x:Name="CloneButton" Style="{StaticResource PrimaryButton}" Content="Clone" Click="Clone_Click" IsEnabled="False"/></StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="2" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="1.1*"/></Grid.ColumnDefinitions>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,9,0"><StackPanel><TextBlock Text="Operation plan" FontSize="17" FontWeight="Bold"/><TextBlock x:Name="PlanText" Text="Load the servers and run an analysis to generate the plan." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/></StackPanel></Border>
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="9,0,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Live log" FontSize="17" FontWeight="Bold"/><ListBox x:Name="LogList" Grid.Row="1" Margin="0,10,0,0"/></Grid></Border>
                </Grid>
            </Grid></TabItem>

            <TabItem Header="Backups"><Grid Margin="34"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Text="Backups" FontSize="30" FontWeight="Bold"/><TextBlock Text="Versioned local snapshots with integrity verification." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22"/></StackPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Refresh" Click="RefreshBackups_Click"/><Button Style="{StaticResource PrimaryButton}" Content="Open folder" Click="OpenBackupFolder_Click"/></StackPanel></DockPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="310"/></Grid.ColumnDefinitions><ListBox x:Name="BackupList" DisplayMemberPath="" SelectionChanged="BackupList_SelectionChanged"/>
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="16,0,0,0"><StackPanel><TextBlock Text="Selected backup" FontSize="17" FontWeight="Bold"/><TextBlock x:Name="BackupDetails" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,18"/><Button Content="Verify integrity" Click="VerifyBackup_Click"/><Button Content="Restore to selected server" Click="RestoreBackup_Click" Margin="0,9,0,0"/></StackPanel></Border>
                </Grid>
            </Grid></TabItem>

            <TabItem Header="Operations"><Grid Margin="34"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Operations" FontSize="30" FontWeight="Bold"/><TextBlock Text="Session history and diagnostics without credentials." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22"/></StackPanel><ListBox x:Name="OperationsList" Grid.Row="1"/></Grid></TabItem>

            <TabItem Header="License"><StackPanel Margin="34"><TextBlock Text="License" FontSize="30" FontWeight="Bold"/><TextBlock x:Name="LicenseDetails" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" FontSize="15" TextWrapping="Wrap"/></StackPanel></TabItem>

            <TabItem Header="Settings"><StackPanel Margin="34"><TextBlock Text="Settings" FontSize="30" FontWeight="Bold"/><TextBlock Text="Security" FontSize="18" FontWeight="Bold" Margin="0,24,0,10"/><Button Width="220" HorizontalAlignment="Left" Content="Delete saved Token" Click="ClearToken_Click"/><Button Width="220" HorizontalAlignment="Left" Content="Sign out" Margin="0,10,0,0" Click="Logout_Click"/><TextBlock Text="Storage" FontSize="18" FontWeight="Bold" Margin="0,24,0,10"/><TextBlock x:Name="BackupPathText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/></StackPanel></TabItem>

            <TabItem Header="Administration"><Grid Margin="34"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left"><TextBlock Text="Administration" FontSize="30" FontWeight="Bold"/><TextBlock Text="Users, approvals, licenses and app releases." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,22"/></StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource PrimaryButton}" Content="Publish app update" Click="PublishUpdate_Click"/><Button Content="Refresh users" Click="LoadAdmin_Click"/></StackPanel>
                </DockPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="310"/></Grid.ColumnDefinitions><ListBox x:Name="AdminUsersList" SelectionChanged="AdminUsersList_SelectionChanged"/>
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="16,0,0,0"><StackPanel><TextBlock Text="Actions" FontSize="17" FontWeight="Bold"/><ComboBox x:Name="LicenseBox" Margin="0,12,0,10" SelectedIndex="0"><ComboBoxItem Content="1 month" Tag="1m"/><ComboBoxItem Content="3 months" Tag="3m"/><ComboBoxItem Content="6 months" Tag="6m"/><ComboBoxItem Content="12 months" Tag="12m"/><ComboBoxItem Content="Permanent" Tag="permanent"/></ComboBox><Button Style="{StaticResource PrimaryButton}" Content="Approve / renew" Click="ApproveUser_Click"/><Button Content="Suspend" Margin="0,8,0,0" Click="SuspendUser_Click"/><Button Content="Reactivate" Margin="0,8,0,0" Click="ReactivateUser_Click"/><Button Content="Revoke" Margin="0,8,0,0" Click="RevokeUser_Click"/></StackPanel></Border>
                </Grid>
            </Grid></TabItem>
        </TabControl>
    </Grid>
</Window>