<Window x:Class="ClonarDC.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clonar DC" Icon="/ClonarDC;component/Assets/ClonarDC.ico"
        Width="980" Height="620" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0B0C14" Padding="60">
            <StackPanel VerticalAlignment="Center">
                <Image Source="/ClonarDC;component/Assets/ClonarDCLogo.png" Width="108" Height="108" HorizontalAlignment="Left" Margin="0,0,0,22"/>
                <TextBlock Text="Clonar DC" FontSize="38" FontWeight="Bold"/>
                <TextBlock Text="Estruturas, backups e clonagem com controle." FontSize="18" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,28" TextWrapping="Wrap"/>
                <TextBlock Text="• Análise antes de alterar" FontSize="15" Margin="0,6"/>
                <TextBlock Text="• Backup automático em operações destrutivas" FontSize="15" Margin="0,6"/>
                <TextBlock Text="• Token protegido localmente no Windows" FontSize="15" Margin="0,6"/>
                <TextBlock Text="• Aplicativo nativo, sem navegador como interface" FontSize="15" Margin="0,6"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" Padding="54">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Entrar" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Acesse sua conta Clonar DC" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,24"/>
                <TextBlock Text="E-mail" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox" Height="42"/>
                <TextBlock Text="Senha" Margin="0,16,0,6"/>
                <PasswordBox x:Name="PasswordBox" Height="42"/>
                <Button x:Name="LoginButton" Style="{StaticResource PrimaryButton}" Content="Entrar" Height="44" Margin="0,22,0,0" Click="LoginButton_Click"/>
                <Button Content="Criar conta" Height="42" Margin="0,10,0,0" Click="RegisterButton_Click"/>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,18,0,0"/>
                <Border x:Name="PendingBox" Visibility="Collapsed" Background="#211936" BorderBrush="#6D28D9" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Esperando autorização" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Status: Pendente" Foreground="#C4B5FD" Margin="0,5,0,0"/>
                        <TextBlock Text="Qualquer dúvida, abra um ticket em Dúvidas no Discord." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>