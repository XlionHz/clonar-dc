<Window x:Class="ClonarDC.TextConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação crítica — Clonar DC" Width="520" Height="330" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="36" Background="{StaticResource PanelBrush}">
        <StackPanel>
            <TextBlock Text="Confirmação necessária" FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="InstructionText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,18"/>
            <TextBox x:Name="ConfirmBox" Height="42"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0"><Button Content="Cancelar" Click="Cancel_Click"/><Button Style="{StaticResource PrimaryButton}" Content="Confirmar" Click="Confirm_Click"/></StackPanel>
        </StackPanel>
    </Border>
</Window>
