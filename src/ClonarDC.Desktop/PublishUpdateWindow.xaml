<Window x:Class="ClonarDC.PublishUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Publish app update — Clonar DC"
        Icon="/ClonarDC;component/Assets/ClonarDC.ico"
        Width="720" Height="690" MinWidth="660" MinHeight="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="34">
            <StackPanel Orientation="Horizontal">
                <Image Source="/ClonarDC;component/Assets/ClonarDCLogo.png" Width="58" Height="58"/>
                <StackPanel Margin="14,3,0,0">
                    <TextBlock x:Name="TitleText" Text="Publish app update" FontSize="28" FontWeight="Bold"/>
                    <TextBlock x:Name="SubtitleText" Text="Send one verified package to every Clonar DC installation." Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,26,0,0">
                <StackPanel>
                    <TextBlock x:Name="PackageHeadingText" Text="1. Update package" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="PackageHelpText" Text="Select the .clonardc-update file supplied with the new version." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="PackagePathBox" IsReadOnly="True" Height="42"/>
                        <Button x:Name="ChoosePackageButton" Grid.Column="1" Content="Choose file" Margin="10,0,0,0" Click="ChoosePackage_Click"/>
                    </Grid>
                    <Border x:Name="PackageInfoBox" Visibility="Collapsed" Background="#151225" BorderBrush="#44336F" BorderThickness="1" CornerRadius="9" Padding="14" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock x:Name="PackageVersionText" FontWeight="Bold"/>
                            <TextBlock x:Name="PackageTitleText" Margin="0,5,0,0"/>
                            <TextBlock x:Name="PackageSizeText" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
                            <TextBlock x:Name="PackageNotesText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock x:Name="AccessHeadingText" Text="2. Publishing key" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="AccessHelpText" Text="Use a fine-grained GitHub token restricted to XlionHz/clonar-dc with Contents: Read and write. The key never goes inside the update package." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                    <PasswordBox x:Name="PublishingKeyBox" Height="42"/>
                    <CheckBox x:Name="RememberKeyCheck" Content="Store this key encrypted for this Windows user" Margin="0,11,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#151225" BorderBrush="#44336F" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,16,0,0">
                <TextBlock x:Name="SecurityNoticeText" Text="Publishing creates a GitHub Release. The app verifies the package SHA-256 before upload; all installed clients then discover the release through the existing updater." Foreground="#C4B5FD" TextWrapping="Wrap"/>
            </Border>

            <ProgressBar x:Name="PublishProgress" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,20,0,0"/>
            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="CancelButton" Content="Close" Click="Close_Click"/>
                <Button x:Name="PublishButton" Style="{StaticResource PrimaryButton}" Content="Publish update to everyone" Click="Publish_Click" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>